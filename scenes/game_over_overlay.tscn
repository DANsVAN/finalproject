[gd_scene format=3 uid="uid://hjtonckxb1lg"]

[ext_resource type="Script" path="res://scripts/GameOverOverlay.cs" id="1_script"]

[node name="GameOverOverlay" type="CanvasLayer"]
process_mode = 3
layer = 100
script = ExtResource("1_script")

[node name="Dim" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.65)
mouse_filter = 2

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(320, 200)
offset_left = -160.0
offset_top = -100.0
offset_right = 160.0
offset_bottom = 100.0

[node name="VBox" type="VBoxContainer" parent="Center/Panel"]
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Center/Panel/VBox"]
horizontal_alignment = 1
text = "Game Over"

[node name="ScoreLabel" type="Label" parent="Center/Panel/VBox"]
unique_name_in_owner = true
horizontal_alignment = 1
text = "Score: 0"

[node name="RoundLabel" type="Label" parent="Center/Panel/VBox"]
unique_name_in_owner = true
horizontal_alignment = 1
text = "Round reached: 1"

[node name="Buttons" type="HBoxContainer" parent="Center/Panel/VBox"]
alignment = 1
theme_override_constants/separation = 16

[node name="HomeButton" type="Button" parent="Center/Panel/VBox/Buttons"]
text = "Return home"

[node name="PlayAgainButton" type="Button" parent="Center/Panel/VBox/Buttons"]
text = "Play again"

[connection signal="pressed" from="Center/Panel/VBox/Buttons/HomeButton" to="." method="_on_home_pressed"]
[connection signal="pressed" from="Center/Panel/VBox/Buttons/PlayAgainButton" to="." method="_on_play_again_pressed"]
